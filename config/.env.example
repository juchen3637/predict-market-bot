# =============================================================================
# predict-market-bot — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to source control.
# =============================================================================

# --- Polymarket ---
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_WALLET_PRIVATE_KEY=       # EIP-712 signing key (Polygon wallet)
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# --- Kalshi (Production) — used for market scanning always ---
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- Kalshi (Demo) — used for order execution when KALSHI_USE_DEMO=true ---
KALSHI_DEMO_API_KEY=                 # Separate key from demo.kalshi.co
KALSHI_DEMO_API_SECRET=              # RSA private key from demo account
KALSHI_DEMO_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_USE_DEMO=true                 # Set to false for live trading

# --- LLM APIs ---
ANTHROPIC_API_KEY=                   # Claude Sonnet (20% ensemble weight)
OPENAI_API_KEY=                      # GPT-4o (20% ensemble weight)
XAI_API_KEY=                         # Grok (30% ensemble weight)
GOOGLE_AI_API_KEY=                   # Gemini Flash (15% ensemble weight)
DEEPSEEK_API_KEY=                    # DeepSeek (15% ensemble weight)

# --- Search Providers ---
SEARCH_PROVIDER=brave                # "brave" | "tavily" — controls scrape_web() dispatch
BRAVE_API_KEY=                       # Required if SEARCH_PROVIDER=brave
TAVILY_API_KEY=                      # Required if SEARCH_PROVIDER=tavily

# --- Data Sources ---
TWITTER_BEARER_TOKEN=                # Twitter/X API v2 bearer token
REDDIT_CLIENT_ID=                    # PRAW app client ID
REDDIT_CLIENT_SECRET=                # PRAW app client secret
REDDIT_USER_AGENT=predict-market-bot/0.1

# --- Operational ---
LOG_LEVEL=INFO
DATA_DIR=./data
MAX_DAILY_AI_COST_USD=30             # Hard cap on AI API spend per day
ALERT_AI_COST_THRESHOLD=0.8          # Alert at 80% of daily cap
PAPER_TRADING=true                   # Set to false for live execution
BANKROLL_USD=100                     # Starting bankroll for position sizing
